<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <svg class="brand-icon" width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="11" height="11" rx="2" fill="white" fill-opacity="0.9" stroke="white" stroke-width="0.5"/>
                <rect x="15" y="1" width="11" height="11" rx="2" fill="white" fill-opacity="0.7" stroke="white" stroke-width="0.5"/>
                <rect x="1" y="15" width="11" height="11" rx="2" fill="white" fill-opacity="0.7" stroke="white" stroke-width="0.5"/>
                <rect x="15" y="15" width="11" height="11" rx="2" fill="white" fill-opacity="0.5" stroke="white" stroke-width="0.5"/>
            </svg>
            <span class="brand-name">PoSeeReview</span>
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <div class="brand-tagline">Strange stories, illustrated</div>
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="leaderboard">
                <span class="bi bi-trophy-fill" aria-hidden="true"></span> Hall of Fame
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
