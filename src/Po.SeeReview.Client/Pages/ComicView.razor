@page "/comic/{PlaceId}"
@using Po.SeeReview.Shared.Dtos
@using Po.SeeReview.Client.Services
@inject ApiClient ApiClient
@inject NavigationManager Navigation
@inject ShareService ShareService

<PageTitle>@(_comic?.RestaurantName ?? "Comic") - PoSeeReview</PageTitle>

<div class="comic-view">
    @if (_isLoading)
    {
        <LoadingIndicator Message="Reading the weird stuff..." />
    }
    else if (_error != null)
    {
        <FluentCard class="error-container">
            <div class="error-icon">🤷</div>
            <h2>@_errorTitle</h2>
            <p class="error-message">@_error</p>
            <FluentButton Appearance="Appearance.Accent" @onclick="GoBack">
                ← Back to Restaurants
            </FluentButton>
        </FluentCard>
    }
    else if (_comic != null)
    {
        <FluentCard class="comic-container">
            <div class="comic-header">
                <h1>@_comic.RestaurantName</h1>
                <div class="strangeness-ring-wrap">
                    <svg class="strangeness-ring" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <circle class="ring-bg" cx="50" cy="50" r="42" />
                        <circle class="ring-fill" cx="50" cy="50" r="42"
                                style="stroke-dasharray: @((_comic.StrangenessScore / 100.0 * 263.9).ToString("F1")) 263.9" />
                    </svg>
                    <div class="ring-label">
                        <span class="ring-score">@_comic.StrangenessScore</span>
                        <span class="ring-text">Weird</span>
                    </div>
                </div>
            </div>

            <ComicStrip ImageUrl="@_comic.BlobUrl" 
                       RestaurantName="@_comic.RestaurantName" 
                       IsCached="@_comic.IsCached" />

            <div class="action-buttons">
                <FluentButton Appearance="Appearance.Accent" @onclick="GoBack">
                    &#8592; @(From == "leaderboard" ? "Back to Hall of Fame" : "Back to Home")
                </FluentButton>
                <FluentButton Appearance="Appearance.Neutral" @onclick="RegenerateComic" Disabled="@_isRegenerating">
                    @if (_isRegenerating)
                    {
                        <text>Regenerating...</text>
                    }
                    else
                    {
                        <text>&#8635; Regenerate</text>
                    }
                </FluentButton>
                <FluentButton Appearance="Appearance.Neutral" @onclick="ShareComic" Disabled="@_isSharing">
                    @if (_isSharing)
                    {
                        <text>Sharing...</text>
                    }
                    else if (_shareSupported)
                    {
                        <text>Share Comic</text>
                    }
                    else
                    {
                        <text>Copy Link</text>
                    }
                </FluentButton>
            </div>
            
            @if (_showCopiedMessage)
            {
                <FluentMessageBar Intent="MessageIntent.Success" class="copied-message">
                    &#10003; Link copied to clipboard!
                </FluentMessageBar>
            }
        </FluentCard>
    }

    @if (_comic != null)
    {
        <div class="share-fab" @onclick="ShareComic" title="@(_shareSupported ? "Share Comic" : "Copy Link")">
            &#128228;
        </div>
    }
</div>

@code {
    [Parameter]
    public string PlaceId { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "from")]
    public string? From { get; set; }

    private ComicDto? _comic;
    private bool _isLoading = true;
    private bool _isSharing = false;
    private bool _isRegenerating = false;
    private bool _shareSupported = false;
    private bool _showCopiedMessage = false;
    private string? _error;
    private string _errorTitle = "Oops!";
    private Timer? _copiedMessageTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadComic(forceRegenerate: false);

        // Auto-regenerate if the comic is older than 7 days
        if (_comic != null && (DateTimeOffset.UtcNow - _comic.GeneratedAt).TotalDays > 7)
        {
            await LoadComic(forceRegenerate: true);
        }

        _shareSupported = await ShareService.IsShareSupportedAsync();
    }

    public void Dispose()
    {
        _copiedMessageTimer?.Dispose();
    }

    private async Task LoadComic(bool forceRegenerate)
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _comic = await ApiClient.GenerateComicAsync(PlaceId, forceRegenerate: forceRegenerate);
        }
        catch (HttpRequestException ex)
        {
            if (ex.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                _errorTitle = "This Place is Refreshingly Normal! 😌";
                _error = "This restaurant doesn't have enough reviews (minimum 5) to generate a comic. The reviews we found were probably too ordinary anyway!";
            }
            else if (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _errorTitle = "Restaurant Not Found";
                _error = "We couldn't find this restaurant. It might have closed or the Google Maps data is unavailable.";
            }
            else
            {
                _errorTitle = "Generation Failed";
                _error = $"Something went wrong while generating the comic. Please try again in a moment. ({ex.Message})";
            }
        }
        catch (Exception ex)
        {
            _errorTitle = "Unexpected Error";
            _error = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo(From == "leaderboard" ? "/leaderboard" : "/");
    }

    private async Task RegenerateComic()
    {
        _isRegenerating = true;
        StateHasChanged();
        try
        {
            await LoadComic(forceRegenerate: true);
        }
        finally
        {
            _isRegenerating = false;
            StateHasChanged();
        }
    }

    private async Task ShareComic()
    {
        if (_comic == null) return;

        _isSharing = true;
        StateHasChanged();

        try
        {
            var currentUrl = Navigation.Uri;
            var title = $"Strange Review Comic - {_comic.RestaurantName}";
            var text = $"Check out this weird review comic! Strangeness: {_comic.StrangenessScore}/100 🎨 #PoSeeReview";

            if (_shareSupported)
            {
                // Use Web Share API
                var shared = await ShareService.ShareComicAsync(title, text, currentUrl);
                
                if (!shared)
                {
                    // User cancelled or error - show message
                    Console.WriteLine("Share cancelled or not supported, copying link instead");
                    await CopyLinkToClipboard(currentUrl);
                }
            }
            else
            {
                // Fallback to clipboard copy
                await CopyLinkToClipboard(currentUrl);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error sharing comic: {ex.Message}");
            // Silently fail - user experience shouldn't be disrupted
        }
        finally
        {
            _isSharing = false;
            StateHasChanged();
        }
    }

    private async Task CopyLinkToClipboard(string url)
    {
        try
        {
            await ShareService.CopyToClipboardAsync(url);
            _showCopiedMessage = true;
            StateHasChanged();

            // Hide message after 3 seconds
            _copiedMessageTimer?.Dispose();
            _copiedMessageTimer = new Timer(_ =>
            {
                _showCopiedMessage = false;
                InvokeAsync(StateHasChanged);
            }, null, 3000, Timeout.Infinite);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error copying to clipboard: {ex.Message}");
        }
    }



}
