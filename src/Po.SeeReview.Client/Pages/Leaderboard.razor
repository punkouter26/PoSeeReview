@page "/leaderboard"
@using Po.SeeReview.Shared.Dtos
@using Po.SeeReview.Client.Services
@inject ApiClient ApiClient
@inject ILogger<Leaderboard> Logger
@inject ShareService ShareService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Hall of Fame - PoSeeReview</PageTitle>

<div class="leaderboard-container">
    <div class="leaderboard-header">
        <h1>Hall of Fame</h1>
        <p class="subtitle">The strangest restaurant experiences from around the world</p>
    </div>

    <div class="region-selector">
        <label for="region">Region:</label>
        <FluentSelect TOption="string" id="region" @bind-Value="selectedRegion" @bind-Value:after="LoadLeaderboardAsync">
            <FluentOption TOption="string" Value="US">United States</FluentOption>
            <FluentOption TOption="string" Value="CA">Canada</FluentOption>
            <FluentOption TOption="string" Value="GB">United Kingdom</FluentOption>
            <FluentOption TOption="string" Value="AU">Australia</FluentOption>
            <FluentOption TOption="string" Value="NZ">New Zealand</FluentOption>
            <FluentOption TOption="string" Value="IE">Ireland</FluentOption>
            <FluentOption TOption="string" Value="IN">India</FluentOption>
            <FluentOption TOption="string" Value="SG">Singapore</FluentOption>
        </FluentSelect>

        <label for="limit">Show:</label>
        <FluentSelect TOption="string" id="limit" @bind-Value="limitStr" @bind-Value:after="OnLimitChangedAsync">
            <FluentOption TOption="string" Value="10">Top 10</FluentOption>
            <FluentOption TOption="string" Value="25">Top 25</FluentOption>
            <FluentOption TOption="string" Value="50">Top 50</FluentOption>
        </FluentSelect>

        @if (isLoading)
        {
            <FluentProgressRing />
        }
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger mt-3" role="alert">
            @errorMessage
        </div>
    }
    else if (leaderboardEntries == null || leaderboardEntries.Count == 0)
    {
        <div class="no-entries">
            <div class="empty-panels">
                <div class="empty-panel">&#128269;</div>
                <div class="empty-panel">&#127869;&#65039;</div>
                <div class="empty-panel">&#129300;</div>
                <div class="empty-panel">&#10067;</div>
            </div>
            <h2 class="empty-title">No Weird Stories Yet!</h2>
            <p class="empty-body">No strange restaurant tales from <strong>@GetRegionName(selectedRegion)</strong> yet.<br />Go discover one — the weirder the better!</p>
            <a href="/" class="empty-home-btn">&#127968; Find Restaurants Near Me</a>
        </div>
    }
    else
    {
        <div class="last-updated">
            <span class="refresh-ring @(isLoading ? "" : "spinning")" title="Auto-refreshing every 30 seconds"></span>
            Last updated: @lastUpdated.ToString("g")
            <span class="refresh-hint">&#8226; Auto-refreshing</span>
        </div>

        <div class="leaderboard-list">
            @foreach (var entry in leaderboardEntries)
            {
                <div class="leaderboard-card @GetRankClass(entry.Rank)">
                    <div class="rank-badge">
                        @if (entry.Rank == 1)
                        {
                            <div class="medal medal-gold">&#127881;</div>
                        }
                        else if (entry.Rank == 2)
                        {
                            <div class="medal medal-silver">&#129352;</div>
                        }
                        else if (entry.Rank == 3)
                        {
                            <div class="medal medal-bronze">&#129353;</div>
                        }
                        else
                        {
                            <div class="medal medal-default">#@entry.Rank</div>
                        }
                    </div>

                    <div class="comic-thumbnail">
                        <img src="@entry.ComicBlobUrl" alt="Comic for @entry.RestaurantName" loading="lazy" />
                    </div>

                    <div class="entry-details">
                        <h3 class="restaurant-name">@entry.RestaurantName</h3>
                        <p class="address">@entry.Address</p>
                        <div class="score-badge">
                            <span class="score-label">Strangeness Score:</span>
                            <span class="score-value">@entry.StrangenessScore.ToString("F0")</span>
                        </div>
                    </div>

                    <div class="entry-actions">
                        <a href="/comic/@entry.PlaceId?from=leaderboard" class="btn btn-primary">View Comic</a>
                        <button class="btn btn-share-small" @onclick="() => ShareComicAsync(entry)" title="Share this comic">
                            &#128228;
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<LeaderboardEntryDto>? leaderboardEntries;
    private string selectedRegion = "US";
    private int limit = 10;
    private string limitStr = "10";
    private DateTimeOffset lastUpdated = DateTimeOffset.MinValue;
    private string? errorMessage;
    private bool isLoading = false;
    private Timer? refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadLeaderboardAsync();
        
        // Set up 30-second auto-refresh
        refreshTimer = new Timer(async _ => 
        {
            await InvokeAsync(async () =>
            {
                await LoadLeaderboardAsync();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task OnLimitChangedAsync()
    {
        if (int.TryParse(limitStr, out var parsed))
            limit = parsed;
        await LoadLeaderboardAsync();
    }

    private async Task LoadLeaderboardAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            Logger.LogInformation("Fetching leaderboard for region {Region} with limit {Limit}", selectedRegion, limit);
            
            var response = await ApiClient.GetLeaderboardAsync(selectedRegion, limit);

            if (response != null)
            {
                leaderboardEntries = response.Entries;
                lastUpdated = response.LastUpdated;
                Logger.LogInformation("Loaded {Count} leaderboard entries", leaderboardEntries.Count);
            }
            else
            {
                errorMessage = "Unable to load leaderboard. Please try again later.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error loading leaderboard");
            errorMessage = "An unexpected error occurred.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetRankClass(int rank)
    {
        return rank switch
        {
            1 => "rank-gold",
            2 => "rank-silver",
            3 => "rank-bronze",
            _ => ""
        };
    }

    private string GetRegionName(string region) => region switch
    {
        "US" => "the United States",
        "CA" => "Canada",
        "GB" => "the United Kingdom",
        "AU" => "Australia",
        "NZ" => "New Zealand",
        "IE" => "Ireland",
        "IN" => "India",
        "SG" => "Singapore",
        _ => region
    };

    private async Task ShareComicAsync(LeaderboardEntryDto entry)
    {
        try
        {
            var comicUrl = $"{Navigation.BaseUri}comic/{entry.PlaceId}";
            var title = $"Strange Review Comic - {entry.RestaurantName}";
            var text = $"Check out this weird review comic! Strangeness: {entry.StrangenessScore:F0}/100 🎨 #PoSeeReview";

            var shareSupported = await ShareService.IsShareSupportedAsync();
            
            if (shareSupported)
            {
                await ShareService.ShareComicAsync(title, text, comicUrl);
            }
            else
            {
                await ShareService.CopyToClipboardAsync(comicUrl);
                // Could show a toast notification here
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error sharing comic for {PlaceId}", entry.PlaceId);
        }
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
    }
}
